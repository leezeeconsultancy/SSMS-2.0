# ─── Database ────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/ssms

# ─── Authentication ───────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5001
NODE_ENV=production

# ─── Admin Seed Credentials (used by `npm run seed`) ─────────────────────────
# Set these before running the seeder in production to create the initial admin
# account with secure credentials.
ADMIN_NAME=System Admin
ADMIN_EMAIL=admin@ssms.com
ADMIN_PASSWORD=Admin@123
